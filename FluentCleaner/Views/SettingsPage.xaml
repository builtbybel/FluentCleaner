<Page
    x:Class="FluentCleaner.Views.SettingsPage"
    NavigationCacheMode="Required"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:FluentCleaner.ViewModels"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <!-- Update banner;shown only when a newer version is available -->
            <InfoBar x:Name="UpdateBar"
                     IsOpen="False"
                     IsClosable="True"
                     Severity="Error" />

            <!-- Donation banner -->
            <InfoBar x:Name="DonationBanner"
                     IsOpen="True"
                     IsClosable="True"
                     Severity="Warning"
                     Title="FluentCleaner is going open source."
                     Message="Put a lot of work into this — if it helps you and you feel like saying thanks, a donation would really mean a lot. ♥">
                <InfoBar.Content>
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                        <Button Content="Support the project"
                                Style="{StaticResource AccentButtonStyle}"
                                Click="Link_Donate" />
                        <Button Content="Maybe later"
                                Click="DonationBanner_Dismiss" />
                    </StackPanel>
                </InfoBar.Content>
            </InfoBar>
        </StackPanel>

    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,26,32,32" Spacing="22" HorizontalAlignment="Stretch">

            <StackPanel Spacing="2">
                <TextBlock Text="Settings" Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock Text="App preferences and database source."
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Style="{StaticResource CaptionTextBlockStyle}" />
            </StackPanel>

            <!-- Theme -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="18,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                        <TextBlock Text="App theme" FontWeight="SemiBold" />
                        <TextBlock Text="Choose how FluentCleaner looks on your device."
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Style="{StaticResource CaptionTextBlockStyle}" />
                    </StackPanel>
                    <ComboBox Grid.Column="1"
                              SelectedIndex="{x:Bind ViewModel.ThemeIndex, Mode=TwoWay}"
                              MinWidth="140" VerticalAlignment="Center">
                        <ComboBoxItem Content="System default" />
                        <ComboBoxItem Content="Light" />
                        <ComboBoxItem Content="Dark" />
                    </ComboBox>
                </Grid>
            </Border>

            <!-- Database -->
            <StackPanel Spacing="10">

                <StackPanel Spacing="2">
                    <TextBlock Text="Database" FontWeight="SemiBold" FontSize="16" />
                    <TextBlock Text="Choose which entry lists are loaded for scanning and cleaning."
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Style="{StaticResource CaptionTextBlockStyle}" />
                </StackPanel>

                <!-- "Active Databases" label + single shared ProgressRing -->
                <Grid Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="Active Databases"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <ProgressRing Width="14" Height="14"
                                      IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
                                      Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay,
                                          Converter={StaticResource BoolToVisibilityConverter}}" />
                        <TextBlock Text="Downloading…" FontSize="11"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center"
                                   Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay,
                                       Converter={StaticResource BoolToVisibilityConverter}}" />
                    </StackPanel>
                </Grid>

                <!-- Database list card -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8">

                    <!-- Winapp2 row -->
                    <StackPanel>
                        <Grid MinHeight="72" Padding="18,0" ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="112" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Icon -->
                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="6"
                                    Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                    Margin="0,0,12,0" VerticalAlignment="Center">
                                <FontIcon Glyph="&#xEA99;" FontSize="18"
                                          Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                            </Border>

                            <!-- Name + info -->
                            <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                                <TextBlock Text="Winapp2" FontWeight="SemiBold" />
                                <TextBlock Text="{x:Bind ViewModel.Winapp2Info, Mode=OneWay}"
                                           FontSize="11"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>

                            <!-- Update button -->
                            <Button Grid.Column="2"
                                    Content="Update"
                                    Command="{x:Bind ViewModel.DownloadLatestCommand}"
                                    HorizontalAlignment="Right"
                                    Visibility="{x:Bind ViewModel.EnableWinapp2, Mode=OneWay,
                                        Converter={StaticResource BoolToVisibilityConverter}}" />

                            <!-- Toggle -->
                            <ToggleSwitch Grid.Column="3"
                                          IsOn="{x:Bind ViewModel.EnableWinapp2, Mode=TwoWay}"
                                          OnContent="" OffContent=""
                                          MinWidth="0" Margin="0,0,-8,0"
                                          VerticalAlignment="Center" />
                        </Grid>

                        <!-- Divider -->
                        <Rectangle Height="1" Fill="{ThemeResource CardStrokeColorDefaultBrush}" />

                        <!-- ── Winapp3 row ── -->
                        <Grid MinHeight="72" Padding="18,0" ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="112" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Icon -->
                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="6"
                                    Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                    Margin="0,0,12,0" VerticalAlignment="Center">
                                <FontIcon Glyph="&#xE7BA;" FontSize="18" Foreground="OrangeRed" />
                            </Border>

                            <!-- Name + info -->
                            <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="Winapp3" FontWeight="SemiBold" />
                                    <Border Background="OrangeRed" CornerRadius="3"
                                            Padding="4,1" VerticalAlignment="Center">
                                        <TextBlock Text="experimental" FontSize="10"
                                                   Foreground="White" />
                                    </Border>
                                </StackPanel>
                                <TextBlock FontSize="11"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                    <Run Text="{x:Bind ViewModel.Winapp3Info, Mode=OneWay}" />
                                    <Run Text="  —  more aggressive entries, use at your own risk."
                                         Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                </TextBlock>
                            </StackPanel>

                            <!-- Download (not yet on disk) / Update (already downloaded) -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal"
                                        HorizontalAlignment="Right" Spacing="6">
                                <Button Content="Download"
                                        Command="{x:Bind ViewModel.DownloadWinapp3Command}"
                                        Visibility="{x:Bind ViewModel.Winapp3NotAvailable, Mode=OneWay,
                                            Converter={StaticResource BoolToVisibilityConverter}}" />
                                <Button Content="Update"
                                        Command="{x:Bind ViewModel.DownloadWinapp3Command}"
                                        Visibility="{x:Bind ViewModel.Winapp3Available, Mode=OneWay,
                                            Converter={StaticResource BoolToVisibilityConverter}}" />
                            </StackPanel>

                            <!-- Toggle -->
                            <ToggleSwitch Grid.Column="3"
                                          IsOn="{x:Bind ViewModel.EnableWinapp3, Mode=TwoWay}"
                                          OnContent="" OffContent=""
                                          MinWidth="0" Margin="0,0,-8,0"
                                          VerticalAlignment="Center" />
                        </Grid>

                        <!-- Divider -->
                        <Rectangle Height="1" Fill="{ThemeResource CardStrokeColorDefaultBrush}" />

                        <!-- Winappx row -->
                        <Grid MinHeight="72" Padding="18,0" ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="112" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Icon -->
                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="6"
                                    Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                    Margin="0,0,12,0" VerticalAlignment="Center">
                                <FontIcon Glyph="&#xE977;" FontSize="18"
                                          Foreground="{ThemeResource SystemFillColorSuccessBrush}" />
                            </Border>

                            <!-- Name + info -->
                            <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="Winappx" FontWeight="SemiBold" />
                                    <Border Background="{ThemeResource SystemFillColorSuccessBrush}"
                                            CornerRadius="3" Padding="4,1" VerticalAlignment="Center">
                                        <TextBlock Text="bloatware" FontSize="10" Foreground="White" />
                                    </Border>
                                </StackPanel>
                                <TextBlock FontSize="11"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                    <Run Text="{x:Bind ViewModel.WinappxInfo, Mode=OneWay}" />
                                    <Run Text="  —  AppX / bloatware entries for the terminal debloater."
                                         Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                </TextBlock>
                            </StackPanel>

                            <!-- Download (not yet on disk) / Update (already downloaded) -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal"
                                        HorizontalAlignment="Right" Spacing="6">
                                <Button Content="Download"
                                        Command="{x:Bind ViewModel.DownloadWinappxCommand}"
                                        Visibility="{x:Bind ViewModel.WinappxNotAvailable, Mode=OneWay,
                                            Converter={StaticResource BoolToVisibilityConverter}}" />
                                <Button Content="Update"
                                        Command="{x:Bind ViewModel.DownloadWinappxCommand}"
                                        Visibility="{x:Bind ViewModel.WinappxAvailable, Mode=OneWay,
                                            Converter={StaticResource BoolToVisibilityConverter}}" />
                            </StackPanel>

                            <!-- Toggle -->
                            <ToggleSwitch Grid.Column="3"
                                          IsOn="{x:Bind ViewModel.EnableWinappx, Mode=TwoWay}"
                                          OnContent="" OffContent=""
                                          MinWidth="0" Margin="0,0,-8,0"
                                          VerticalAlignment="Center" />
                        </Grid>

                        <!-- Divider -->
                        <Rectangle Height="1" Fill="{ThemeResource CardStrokeColorDefaultBrush}" />

                        <!--Status / error text -->
                        <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                                   FontSize="11" Margin="18,8,18,8"
                                   Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                   TextWrapping="WrapWholeWords"
                                   Visibility="{x:Bind ViewModel.StatusText, Mode=OneWay,
                                       Converter={StaticResource NullToVisibilityConverter}}" />

                        <!-- Divider -->
                        <Rectangle Height="1" Fill="{ThemeResource CardStrokeColorDefaultBrush}"
                                   Visibility="{x:Bind ViewModel.StatusText, Mode=OneWay,
                                       Converter={StaticResource NullToVisibilityConverter}}" />

                        <!-- Custom path row -->
                        <Grid MinHeight="76" Padding="18,0" ColumnSpacing="14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Icon -->
                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="6"
                                    Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                    Margin="0,0,12,0" VerticalAlignment="Center">
                                <FontIcon Glyph="&#xE8B7;" FontSize="18"
                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </Border>

                            <!-- Path input (always visible) -->
                            <Grid Grid.Column="1" ColumnSpacing="8" VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0"
                                         PlaceholderText="Custom database path (.ini)"
                                         Text="{x:Bind ViewModel.CustomPath, Mode=TwoWay,
                                                UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="12"
                                         MinWidth="360" />
                                <Button Grid.Column="1" Content="Browse…"
                                        Click="BrowseButton_Click" />
                            </Grid>

                            <!-- Apply / Remove -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal"
                                        Spacing="8" VerticalAlignment="Center">
                                <Button Content="Apply"
                                        Style="{StaticResource AccentButtonStyle}"
                                        Command="{x:Bind ViewModel.ApplyCustomPathCommand}" />
                                <Button Command="{x:Bind ViewModel.RemoveCustomPathCommand}"
                                        Visibility="{x:Bind ViewModel.IsCustomSource, Mode=OneWay,
                                            Converter={StaticResource BoolToVisibilityConverter}}"
                                        ToolTipService.ToolTip="Remove custom database">
                                    <FontIcon Glyph="&#xE711;" FontSize="12" />
                                </Button>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Restart notice -->
                <InfoBar IsOpen="{x:Bind ViewModel.RestartRequired, Mode=OneWay}"
                         IsClosable="True" Severity="Warning"
                         Title="Restart required"
                         Message="Please restart FluentCleaner to load the updated database." />

            </StackPanel>

            <!-- Post-clean tasks  -->
            <StackPanel Spacing="8">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Spacing="2">
                        <TextBlock Text="Post-clean tasks" FontWeight="SemiBold" FontSize="16" />
                        <TextBlock Text="One command per line — runs sequentially after every clean pass."
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Style="{StaticResource CaptionTextBlockStyle}" />
                    </StackPanel>

                    <ToggleSwitch Grid.Column="1"
                                  IsOn="{x:Bind ViewModel.PostCleanEnabled, Mode=TwoWay}"
                                  OnContent=""
                                  OffContent=""
                                  MinWidth="0"
                                  Margin="12,0,-8,0"
                                  VerticalAlignment="Center" />
                </Grid>

                <!-- just Plain code-style text box;user types one command per line -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                    <TextBox Text="{x:Bind ViewModel.PostCleanCommands, Mode=TwoWay,
                                        UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"
                             FontFamily="Consolas"
                             FontSize="12"
                             MinHeight="116"
                             IsEnabled="{x:Bind ViewModel.PostCleanEnabled, Mode=OneWay}"
                             TextWrapping="NoWrap"
                             BorderThickness="0"
                             Padding="12"
                             PlaceholderText="cleanmgr.exe /sageset:1&#x0a;cleanmgr.exe /sagerun:1&#x0a;start &quot;&quot; ms-settings:storagesense&#x0a;taskkill /f /im explorer.exe &amp; start explorer.exe" />
                </Border>
            </StackPanel>
            <!-- End post-clean tasks -->

            <!-- About -->
            <Expander x:Name="AboutExpander"
                      HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Stretch">
                <Expander.Header>
                    <Grid Margin="4,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Icon -->
                        <Border Grid.Column="0"
                                Width="36" Height="36"
                                CornerRadius="8"
                                Margin="0,0,12,0">
                            <Image Source="ms-appx:///Assets/AppIconAlt.ico" Stretch="UniformToFill" />
                        </Border>

                        <!-- Name + copyright -->
                        <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <TextBlock Text="FluentCleaner" FontWeight="SemiBold" />
                                <Border Visibility="{x:Bind InsiderBadgeVisibility}"
                                        Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                        BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="3" Padding="5,1"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="INSIDER" FontSize="9" FontWeight="SemiBold"
                                               Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                                </Border>
                            </StackPanel>
                            <TextBlock Text="© 2026 A Belim app creation"
                                       FontSize="11"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>

                        <!-- Version -->
                        <TextBlock Grid.Column="2"
                                   Text="{x:Bind AppVersion}"
                                   FontSize="13"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0" />
                    </Grid>
                </Expander.Header>

                <StackPanel Spacing="2" Margin="0,4,0,8">
                    <HyperlinkButton Content="GitHub"
                                     Click="Link_GitHub" />
                    <HyperlinkButton Content="Report an issue"
                                     Click="Link_Issues" />
                    <HyperlinkButton Content="What's new"
                                     Click="Link_Releases" />
                    <StackPanel Orientation="Horizontal" Spacing="4" Margin="11,4,0,0">
                        <TextBlock Text="App icon by"
                                   FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center" />
                        <HyperlinkButton Content="naderi"
                                         NavigateUri="https://github.com/naderi"
                                         FontSize="12" Padding="0,0,0,1"
                                         VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>
            </Expander>
        </StackPanel>
    </ScrollViewer>
    </Grid>
</Page>